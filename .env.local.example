# Get these from: https://supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# Service role key — server-only, never expose to client. Used by the Stripe webhook to bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Stripe — Dashboard → Developers → API keys
# Code picks TEST in dev (NODE_ENV !== 'production') and LIVE in prod automatically.
STRIPE_SECRET_KEY_TEST=sk_test_...
STRIPE_SECRET_KEY_LIVE=sk_live_...
STRIPE_PUBLIC_KEY_TEST=pk_test_...
STRIPE_PUBLIC_KEY_LIVE=pk_live_...

# Stripe webhook signing secret — locally use `stripe listen` output; in prod set per webhook endpoint
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs for the Pro plan (one product, two recurring prices).
# These are IDs like `price_1ABC…`, NOT amounts. Create the product + prices in Stripe Dashboard.
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_YEARLY=price_...

# Public base URL for Stripe success/cancel redirects
NEXT_PUBLIC_APP_URL=http://localhost:3000
